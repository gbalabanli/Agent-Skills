{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/design-to-code-annotator.schema.json",
  "title": "DesignToCodeAnnotationProject",
  "type": "object",
  "required": ["project_id", "project_title", "feature_summary", "screens"],
  "properties": {
    "project_id": { "type": "string", "minLength": 1 },
    "project_title": { "type": "string", "minLength": 1 },
    "feature_summary": { "type": "string", "minLength": 1 },
    "screens": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/screen" }
    },
    "links": {
      "type": "array",
      "items": { "$ref": "#/$defs/link" }
    }
  },
  "$defs": {
    "screen": {
      "type": "object",
      "required": ["screen_id", "screen_title", "image_path", "annotations"],
      "properties": {
        "screen_id": { "type": "string", "minLength": 1 },
        "screen_title": { "type": "string", "minLength": 1 },
        "image_path": { "type": "string", "minLength": 1 },
        "screen_notes": { "type": "string" },
        "annotations": {
          "type": "array",
          "items": { "$ref": "#/$defs/annotation" }
        }
      },
      "additionalProperties": false
    },
    "annotation": {
      "type": "object",
      "required": [
        "annotation_id",
        "label",
        "x",
        "y",
        "width",
        "height",
        "interaction_type",
        "description",
        "expected_result",
        "target_screen_id",
        "component_hint",
        "development_notes",
        "priority"
      ],
      "properties": {
        "annotation_id": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "x": { "type": "number", "minimum": 0, "maximum": 1 },
        "y": { "type": "number", "minimum": 0, "maximum": 1 },
        "width": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 },
        "height": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 },
        "interaction_type": {
          "type": "string",
          "enum": ["click", "tap", "input", "hover", "scroll", "view", "submit", "navigate", "custom"]
        },
        "description": { "type": "string", "minLength": 1 },
        "expected_result": { "type": "string", "minLength": 1 },
        "target_screen_id": {
          "oneOf": [
            { "type": "string", "minLength": 1 },
            { "type": "null" }
          ]
        },
        "component_hint": { "type": "string", "minLength": 1 },
        "development_notes": { "type": "string", "minLength": 1 },
        "priority": { "type": "string", "enum": ["high", "medium", "low"] },
        "state_before": { "type": "string" },
        "state_after": { "type": "string" },
        "data_dependencies": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "link": {
      "type": "object",
      "required": ["link_id", "from_screen_id", "from_annotation_id", "to_screen_id", "transition_note"],
      "properties": {
        "link_id": { "type": "string", "minLength": 1 },
        "from_screen_id": { "type": "string", "minLength": 1 },
        "from_annotation_id": { "type": "string", "minLength": 1 },
        "to_screen_id": { "type": "string", "minLength": 1 },
        "transition_note": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
